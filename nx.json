{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build:translations": {
      "outputs": [
        "{projectRoot}/**/autoGeneratedTranslations.js"
      ],
      "inputs": [
        "{projectRoot}/public/locales/**/*.json",
        "{workspaceRoot}/public/locales/**/*.json"
      ],
      "cache": true
    },
    "build": {
      "cache": true,
      "outputs": [
        "{projectRoot}/.next",
        "{projectRoot}/dist"
      ]
    },
    "build:deploy": {
      "cache": true,
      "outputs": [
        "{projectRoot}/.next"
      ]
    },
    "deploy": {
      "cache": false
    },
    "storybook-build": {
      "cache": true,
      "outputs": [
        "{projectRoot}/storybook-static"
      ]
    },
    "test:build": {
      "cache": true,
      "outputs": [
        "{projectRoot}/.next"
      ]
    },
    "test": {
      "cache": true,
      "inputs": [
        "{workspaceRoot}/packages/shared/**/*"
      ]
    }
  },
  "defaultBase": "develop",
  "tui": {
    "enabled": false
  }
}
