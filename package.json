{
  "name": "docspace",
  "version": "3.6.1",
  "private": true,
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm nx run-many -t build -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk",
    "build:lite": "pnpm nx run-many -t build -p @docspace/client @docspace/login @docspace/doceditor",
    "bump": "pnpm version --workspace",
    "clean": "pnpm -r run clean",
    "deploy": "shx rm -rf ../publish/web && pnpm nx run-many -t deploy -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk && shx cp -r public ../publish/web/ && node common/scripts/minify-common-locales.js",
    "deploy:lite": "shx rm -rf ../publish/web && pnpm nx run-many -t deploy -p @docspace/client @docspace/login @docspace/doceditor && shx cp -r public ../publish/web/ && node common/scripts/minify-common-locales.js",
    "deploy:preview": "shx rm -rf ../publish/web && pnpm nx run-many -t build:deploy -p @docspace/login @docspace/doceditor @docspace/management @docspace/sdk && pnpm nx deploy @docspace/client && node common/scripts/preview/deploy.js && shx cp -r public ../publish/web/ && node common/scripts/minify-common-locales.js",
    "start": "pnpm nx run-many -t start -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk",
    "start:sdk": "pnpm nx run-many -t start -p @docspace/client @docspace/doceditor @docspace/sdk",
    "start:lite": "pnpm nx run-many -t start -p @docspace/client @docspace/login @docspace/doceditor",
    "start-prod": "pnpm nx run-many -t start-prod -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk",
    "start-prod:sdk": "pnpm nx run-many -t start-prod -p @docspace/client @docspace/doceditor @docspace/sdk",
    "start-prod:lite": "pnpm nx run-many -t start-prod -p @docspace/client @docspace/login @docspace/doceditor",
    "storybook": "pnpm nx storybook @docspace/shared",
    "storybook-build": "pnpm nx storybook-build @docspace/shared",
    "storybook-serve": "pnpm nx storybook-serve @docspace/shared",
    "test": "pnpm nx test @docspace/shared",
    "wipe": "pnpm nx reset && shx rm -rf node_modules pnpm-lock.yaml packages/**/node_modules",
    "licenses-audit": "node scripts/check-licenses.js",
    "licenses-aggregate": "node scripts/aggregate-licenses.js",
    "check-circular": "pnpm madge --circular ./packages",
    "check-circular:graph": "pnpm madge --circular --image graph.svg ./packages",
    "lint": "pnpm nx run-many -t lint -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk @docspace/shared",
    "lint:fix": "pnpm nx run-many -t lint:fix -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk @docspace/shared",
    "format": "pnpm nx run-many -t format -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk @docspace/shared",
    "format:fix": "pnpm nx run-many -t format:fix -p @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk @docspace/shared",
    "tsc": "pnpm nx run-many -t tsc @docspace/client @docspace/login @docspace/doceditor @docspace/management @docspace/sdk @docspace/shared",
    "prepare": "node -e \"if (!process.env.CI) { try { require('child_process').execSync('git --version', {stdio: 'ignore'}); require('child_process').execSync('lefthook install', {stdio: 'inherit'}); } catch (e) { console.error('Lefthook installation skipped:', e.message); } }\" && npm --prefix ./common/tests ci",
    "update-ui-kit-lock": "mv pnpm-workspace.yaml pnpm-workspace.yaml.bak && cd libs/ui-kit && pnpm install --lockfile-only; cd ../.. && mv pnpm-workspace.yaml.bak pnpm-workspace.yaml"
  },
  "devDependencies": {
    "@types/node": "24.10.7",
    "@types/react-text-mask": "5.4.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "he": "1.2.0",
    "lefthook": "^2.1.4",
    "madge": "8.0.0",
    "nx": "22.4.5",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "shx": "0.4.0",
    "terser": "5.46.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "overrides": {
      "pnpm": "^10.28.2",
      "on-headers": "^1.1.0",
      "@types/react": "19.2.10",
      "@types/react-dom": "19.2.3",
      "@smithy/config-resolver": "4.4.6",
      "diff": "4.0.4",
      "lodash": "4.17.23",
      "js-yaml": ">=4.1.1",
      "node-forge": ">=1.3.2",
      "mdast-util-to-hast": ">=13.2.1",
      "express": ">=5.2.1",
      "qs": ">=6.14.2",
      "node-fetch": ">=2.6.7",
      "ajv": ">=8.18.0",
      "fast-xml-parser": ">=5.5.7",
      "minimatch": ">=10.2.1",
      "serialize-javascript": ">=7.0.3",
      "immutable": ">=5.1.5",
      "@svgr/plugin-svgo>svgo": "~3.3.3",
      "postcss-svgo>svgo": ">=4.0.1",
      "file-type": ">=21.3.2",
      "flatted": ">=3.4.0"
    }
  }
}