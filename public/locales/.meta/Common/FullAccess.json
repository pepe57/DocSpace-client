  "comment": {
    "text": "This key represents the highest level of access granted to a shared folder or file. It's used to display the access level in the UI, specifically within access level cells and share settings, indicating the user has full read and write permissions. Translators should ensure the translation accurately conveys the scope of this access level.",
    "is_auto": true,
    "updated_at": "2025-09-23T07:25:59.777Z"
  },
