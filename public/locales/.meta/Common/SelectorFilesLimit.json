  "comment": {
    "text": "This key displays a limit on the number of files that can be selected, informing the user how many files are allowed. It appears in a file selection interface, likely within a chat attachment component on mobile devices, to show the maximum file upload count. The `count` variable will be replaced with the actual file limit value.",
    "is_auto": true,
    "updated_at": "2025-11-13T08:04:15.993Z"
  },
