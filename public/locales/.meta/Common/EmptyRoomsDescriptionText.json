  "comment": {
    "text": "This text is a prompt displayed when a user navigates to a section with no existing rooms. It instructs the user to create the first room within that section (e.g., \"Please create the first room in My Files.\"). The `sectionName` variable is dynamically populated with the name of the section.",
    "is_auto": true,
    "updated_at": "2025-10-27T16:38:31.234Z"
  },
