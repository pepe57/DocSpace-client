  "comment": {
    "text": "The \"GotIt\" translation key is used to display a confirmation button that indicates agreement or acceptance of information in UI elements such as buttons and dialogs. It is typically used in scenarios where the user needs to acknowledge understanding or accept terms, allowing them to proceed with the desired action. This text appears on primary buttons in dialog components and guidance sections.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:36:01.190Z"
  },
