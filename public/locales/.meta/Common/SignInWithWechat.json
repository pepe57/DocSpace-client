  "comment": {
    "text": "This key provides the text for a button or link that allows users to sign in or sign up using their WeChat account. It appears when the user is signing in (not signing up) and chooses WeChat as their authentication method. Translators should ensure the phrasing accurately reflects the action of signing in with WeChat.",
    "is_auto": true,
    "updated_at": "2025-09-09T10:40:28.908Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/utils/common.tsx",
      "line_number": 489,
      "context": "case \"zoom\":\n return signUp ? t(\"Common:SignUpWithZoom\") : t(\"Common:SignInWithZoom\");\n case \"weixin\":\n return signUp\n ? t(\"Common:SignUpWithWechat\")\n : t(\"Common:SignInWithWechat\");\n default:\n return \"\";\n }\n }",
      "module": "/packages/shared"
    }
