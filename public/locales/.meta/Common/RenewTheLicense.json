  "comment": {
    "text": "This key displays the text \"Renew the license\" when the user doesn't have a lifetime license. It's used within the EnterpriseContainer component to prompt users to renew their license, likely as a button or link in the UI.",
    "is_auto": true,
    "updated_at": "2026-03-20T09:13:26.232Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/pages/Payments/Standalone/sub-components/EnterpriseContainer.tsx",
      "line_number": 65,
      "context": "return (\n <div className={styles.enterpriseComponent}>\n <Text fontWeight={700} fontSize=\"16px\">\n {!isLifetimeLicense\n ? t(\"RenewTheLicense\")\n : t(\"ActivateRenewSubscriptionHeader\", {\n license: isDeveloper\n ? t(\"Common:DeveloperLicense\")\n : t(\"Common:EnterpriseLicense\"),\n })}",
      "module": "/packages/shared"
    }
  ],
