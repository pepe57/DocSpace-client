  "comment": {
    "text": "This key displays a badge label indicating whether a template is modified or the default version. It appears on a TemplatesRow component within the Portal Settings, specifically on a badge element to differentiate between customized and default templates. Translators should ensure the translation accurately reflects the meaning of \"modified\" versus \"original.\"",
    "is_auto": true,
    "updated_at": "2026-03-20T09:22:48.359Z"
  },
  "usage": [
