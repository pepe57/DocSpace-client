      "context": "</div>\n \n <Badge\n className={styles.badge}\n backgroundColor={badgeBackgroundColor}\n label={item.isModified ? t(\"Common:Customized\") : t(\"Common:Default\")}\n noHover\n fontSize=\"9px\"\n fontWeight={700}\n lineHeight=\"100%\"\n padding=\"2px 5px\"",
      "module": "/packages/client"
