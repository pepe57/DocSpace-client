  "comment": {
    "text": "This is an error message displayed in a dialog header when the user's portal storage quota has been exceeded. `{{productName}}` will be replaced with the product's brand name (e.g., \"ONLYOFFICE DocSpace\").",
    "is_auto": true,
    "updated_at": "2026-04-11T20:46:13.811Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
