      "context": "return {\n description: initial\n ? t(\"EditingUnavailable\")\n : t(\"YourFurtherEditsNotSaved\"),\n header: initial\n ? t(\"PortalQuotaReached\", {\n productName: getBrandName(\"ProductName\"),\n })\n : t(\"PortalQuotaLimitWarning\", {\n productName: getBrandName(\"ProductName\"),\n }),",
      "module": "/packages/doceditor"
    }
