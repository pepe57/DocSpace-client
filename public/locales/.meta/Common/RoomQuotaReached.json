  "comment": {
    "text": "This key displays a message within a bar component, likely a warning or notification, indicating that the maximum number of users or objects allowed in a room has been reached. It's used to inform the user that they cannot proceed further due to a quota limit. The message appears in the UI when editing a room.",
    "is_auto": true,
    "updated_at": "2026-03-20T09:11:38.638Z"
  },
  "usage": [
    {
      "file_path": "/packages/doceditor/src/components/Bar/index.tsx",
      "line_number": 56,
      "context": "case \"room\":\n return {\n description: initial\n ? t(\"EditingUnavailable\")\n : t(\"YourFurtherEditsNotSaved\"),\n header: initial ? t(\"RoomQuotaReached\") : t(\"RoomQuotaLimitWarning\"),\n };\n case \"user\":\n return {\n description: initial\n ? t(\"EditingUnavailable\")",
      "module": "/packages/doceditor"
    }
