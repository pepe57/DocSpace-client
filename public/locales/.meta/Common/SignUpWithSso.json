    "text": "This translation key is used to display a sign-up option via Single Sign-On (SSO) method in the UI. It appears as a button or dialog prompt where users can choose to sign up using their SSO credentials. The purpose of this text is to inform users about an alternative way to create an account.",
    "is_auto": true,
    "updated_at": "2025-05-20T08:39:47.745Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/utils/common.tsx",
      "line_number": 481,
      "context": "case \"microsoft\":\n return signUp\n ? t(\"Common:SignUpWithMicrosoft\")\n : t(\"Common:SignInWithMicrosoft\");\n case \"sso\":\n return signUp ? t(\"Common:SignUpWithSso\") : t(\"Common:SignInWithSso\");\n case \"zoom\":\n return signUp ? t(\"Common:SignUpWithZoom\") : t(\"Common:SignInWithZoom\");\n case \"weixin\":\n return signUp\n ? t(\"Common:SignUpWithWechat\")",
      "module": "/packages/shared"
    }
