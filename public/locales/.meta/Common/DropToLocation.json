  "comment": {
    "text": "This key displays a tooltip on a button indicating the destination folder when dropping a file. The text \"Drop to: {{folderName}}\" informs the user where the file will be placed. Translators should ensure the destination folder name is clearly communicated.",
    "is_auto": true,
    "updated_at": "2025-08-11T18:12:30.269Z"
  },
  "usage": [
    {
      "file_path": "/libs/ui-kit/components/operations-progress-button/PreviewButton.tsx",
      "line_number": 305,
      "context": "tooltipContent={\n animationState !== \"hidingUnder\" &&\n animationState !== \"dropping\" &&\n (dropTargetFolderName || lastKnownTitle) ? (\n <Text fontWeight={600} fontSize=\"14px\">\n {/* t(\"Common:DropToLocation\", { folderName: dropTargetFolderName || lastKnownTitle }) */}\n {t(\"DropToLocation\", {\n folderName: dropTargetFolderName! || lastKnownTitle!,\n })}\n </Text>\n ) : null",
      "module": "/libs/ui-kit"
    },
