  "comment": {
    "text": "This key displays an error message informing the user about the acceptable length range for a brand name. It appears within a form field, likely during brand name creation or editing, to guide the user to enter a name between 2 and 40 characters. Translators should ensure the message accurately conveys the length constraints.",
    "is_auto": true,
    "updated_at": "2025-08-04T08:11:35.229Z"
  },
