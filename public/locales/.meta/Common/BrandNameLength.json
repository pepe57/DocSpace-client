  "comment": {
    "text": "This is an error message that appears when the entered brand name is too short or too long. It informs the user about the required minimum and maximum length for the brand name. `{{minLength}}` and `{{maxLength}}` are numbers representing these limits.",
    "is_auto": true,
    "updated_at": "2026-04-11T20:58:07.141Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
