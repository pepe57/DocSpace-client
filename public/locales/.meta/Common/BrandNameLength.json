      "file_path": "/packages/shared/pages/Branding/BrandName/index.tsx",
      "line_number": 124,
      "context": "switch (error) {\n case \"Empty\":\n return t(\"Common:EmptyFieldError\");\n case \"MinLength\":\n return t(\"Common:BrandNameLength\", {\n minLength: 2,\n maxLength: 40,\n });\n case \"SpecSymbols\":\n return t(\"Common:BrandNameForbidden\");",
      "module": "/packages/shared"
    }
