    "text": "This translation key is used to display a label on a user menu item for accessing support and feedback features. It appears in the user menu, allowing users to access common feedback and support options. The exact UI component this label is part of can be found at /packages/client/src/store/ProfileActionsStore.js line 439.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:36:15.957Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/store/ProfileActionsStore.js",
      "line_number": 497,
      "context": "},\n liveChat,\n feedbackAndSupportEnabled && {\n key: \"user-menu-support\",\n icon: EmailReactSvgUrl,\n label: t(\"Common:FeedbackAndSupport\"),\n onClick: this.onSupportClick,\n url: this.settingsStore.feedbackAndSupportUrl || \"#\",\n preventNewTab: true,\n },\n feedbackAndSupportEnabled && {",
      "module": "/packages/client"
    }
  ],
