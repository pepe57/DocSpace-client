      "line_number": 708,
      "context": "if (status) {\n if (t) toastr.success(t(\"Common:PluginEnabled\"));\n this.activatePlugin(name);\n } else {\n if (t) toastr.success(t(\"Common:PluginDisabled\"));\n this.deactivatePlugin(name);\n }\n \n return plugin;\n } catch (e) {",
      "module": "/packages/client"
    }
