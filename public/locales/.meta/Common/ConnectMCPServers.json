  "comment": {
    "text": "This is a tooltip message that appears when the \"Manage connection\" option is disabled. It informs the user that they need to connect to {{mcpServers}} (which is a placeholder for \"MCP servers\") within the room settings to enable this feature.",
    "is_auto": true,
    "updated_at": "2026-04-11T20:56:36.289Z",
    "model": "google/gemini-2.5-flash"
  },
