  "comment": {
    "text": "This text appears as a tooltip on a button within room settings. It instructs users to connect Minecraft server instances (MCP servers) to manage connections. The `{{mcpServers}}` placeholder will be replaced with a label for MCP settings.",
    "is_auto": true,
    "updated_at": "2025-12-22T09:45:27.052Z"
  },
