      "context": "let invalidEmailDescription = isOwner\n ? t(\"UnknownPayerForOwner\", {\n productName: getBrandName(\"ProductName\"),\n })\n : t(\"UnknownPayerForAdmin\", {\n productName: getBrandName(\"ProductName\"),\n });\n \n if (isNotPaidPeriod) {\n invalidEmailDescription = isOwner",
      "module": "/libs/ui-kit"
