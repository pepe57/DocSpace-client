{
  "key_path": "UnknownPayerForAdmin",
  "content": "We couldn’t find a contact matching the Stripe email. Billing and services will continue to work, but we recommend contacting the {{productName}} owner to assign a new Payer.",
  "content_en_sha1_hash": "fc41ef37a720cd1e3c3ec6ec5ad2ab4962d51a9b",
  "created_at": "2026-04-10T13:53:43.783Z",
  "updated_at": "2026-04-12T07:14:23.190Z",
  "comment": {
    "text": "This is an error message displayed to an administrator when the system cannot find a Stripe contact for the current payer. It informs them that billing will continue but advises contacting the product owner to assign a new payer. `{{productName}}` will be replaced with the product's brand name.",
    "is_auto": true,
    "updated_at": "2026-04-11T20:40:13.654Z",
    "model": "google/gemini-2.5-flash"
  },
