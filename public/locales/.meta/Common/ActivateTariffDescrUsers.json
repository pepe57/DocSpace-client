  "comment": {
    "text": "This is a descriptive text displayed in the tariff title container. It informs the user about their current license usage, specifically the number of active users versus the total allowed. `{{organizationName}}` is the name of the organization, `{{productName}}` is the product name (e.g., DocSpace), `{{license}}` is the type of license, `{{editingCount}}` is the number of users currently editing, and `{{limit}}` is the maximum number of users allowed.",
    "is_auto": true,
    "updated_at": "2026-04-11T21:01:14.799Z",
    "model": "google/gemini-2.5-flash"
  },
