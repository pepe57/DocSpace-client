    "text": "\"Connecting account\" is used as a title in a reconnect storage or connecting account dialogue. It appears on the header of a ConnectDialog component when reconnecting to an account.",
    "is_auto": true,
    "updated_at": "2025-05-26T08:06:19.577Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/dialogs/connect/ConnectDialog.tsx",
      "line_number": 107,
      "context": "const isAccount = !!link;\n const showUrlField = !!connectItem?.requiredConnectionUrl;\n \n const header = isConnectDialogReconnect\n ? t(\"Common:ReconnectStorage\")\n : t(\"Common:ConnectingAccount\");\n \n const onChangeUrl = (e: React.ChangeEvent<HTMLInputElement>) => {\n setIsUrlValid(true);\n setUrlValue(e.target.value);\n };",
      "module": "/packages/shared"
    }
