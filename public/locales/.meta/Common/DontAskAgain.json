      "context": "padding: \"16px 0 0\",\n }}\n >\n <Checkbox\n className=\"dont-ask-again\"\n label={t(\"Common:DontAskAgain\")}\n isChecked={isChecked}\n onChange={onChangeCheckbox}\n dataTestId={`${getTestIdPrefix()}_dont_ask_again`}\n />\n </div>",
      "module": "/packages/client"
    },
    {
      "file_path": "/packages/client/src/pages/Profile/Section/Body/sub-components/file-management/index.tsx",
