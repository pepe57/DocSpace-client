  "comment": {
    "text": "This is an error message displayed to the owner of a DocSpace portal when the system cannot find a matching Stripe contact for billing. It informs the owner that services will continue but advises assigning a new Payer. `{{productName}}` is a placeholder for the product's brand name.",
    "is_auto": true,
    "updated_at": "2026-04-11T20:40:12.310Z",
