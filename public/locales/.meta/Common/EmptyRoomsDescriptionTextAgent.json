    "text": "This text provides a description for the first agent when the agent section is empty. It's used to guide the user and appears as a message in the UI within the agent section. The `sectionName` variable will be replaced with \"AIAgents\" for context.",
    "is_auto": true,
    "updated_at": "2025-11-03T12:13:10.305Z"
  },
