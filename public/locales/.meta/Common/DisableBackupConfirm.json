{
  "key_path": "DisableBackupConfirm",
  "content": "Disabling the Backup service will prevent {{productName}} administrators from creating backups. If Auto Backup is enabled, it will remain active within the free quota, but once the quota is fully utilized, it will be permanently deactivated. Are you sure you want to continue?",
  "content_en_sha1_hash": "a19b1a1308b0013c64babf5fade04f0a7951608a",
  "created_at": "2026-04-10T13:53:45.022Z",
  "updated_at": "2026-04-23T17:24:02.177Z",
  "comment": {
    "text": "This is the body text of a confirmation dialog that appears when a user attempts to disable the Backup service. It warns about the consequences of disabling the service, including the impact on administrators' ability to create backups and the eventual deactivation of Auto Backup once the free quota is used. The `{{productName}}` variable will be replaced with the actual product name (e.g., \"ONLYOFFICE DocSpace\").",
    "is_auto": true,
    "updated_at": "2026-04-11T20:55:04.200Z",
    "model": "google/gemini-2.5-flash"
  },
