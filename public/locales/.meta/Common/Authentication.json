      "context": "return (\n <>\n <div className=\"ldap_authentication-header\">\n <ToggleButton\n label={t(\"Common:Authentication\")}\n className=\"toggle\"\n isChecked={authentication}\n onChange={setIsAuthentication}\n isDisabled={!isLdapEnabled || isUIDisabled}\n />",
      "module": "/packages/client"
