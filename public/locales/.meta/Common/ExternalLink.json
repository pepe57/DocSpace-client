  "comment": {
    "text": "This key displays the label \"External link\" next to a help button within controls groups in various file selection components (FileSelector.js, Manager.js, SimpleRoom.js). It indicates that a link is publicly accessible and provides information about public room details via the associated tooltip. Translators should ensure the translated text accurately conveys the meaning of a publicly shared link.",
    "is_auto": true,
    "updated_at": "2026-03-20T09:20:12.597Z"
  },
