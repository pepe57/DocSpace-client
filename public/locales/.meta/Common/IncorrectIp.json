  "comment": {
    "text": "This key displays an error message when the user enters an invalid IP address in the IP security settings. It appears within a form or input field validation to inform the user about the incorrect format of their IP address. Translators should ensure the message clearly conveys the need for a properly formatted IP.",
    "is_auto": true,
    "updated_at": "2025-12-17T07:51:14.789Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/security/access-portal/ipSecurity.js",
      "line_number": 186,
      "context": "const getErrorMessage = (ip, index, ipsArray = ips) => {\n const isDuplicate = checkDuplicate(ipsArray, ip, index);\n const isValidFormat = isValidIp(ip) && ip !== \"\";\n \n if (isDuplicate) return t(\"Common:IpAlreadyAdded\");\n if (!isValidFormat) return t(\"Common:IncorrectIp\");\n return null;\n };\n \n const validateAllIps = (ipsArray) => {\n return ipsArray.map((ip, index) => getErrorMessage(ip, index, ipsArray));",
      "module": "/packages/client"
    }
  ],
