  "comment": {
    "text": "This text explains why a user cannot disable download and copy restrictions. It appears as a tooltip in a dialog (EditLinkPanel) when download restrictions are enforced at the room level, informing the user that the setting cannot be changed. Translators should convey the reason for the restriction.",
    "is_auto": true,
    "updated_at": "2025-08-26T11:18:07.011Z"
  },
