  "key_path": "RestrictionDownloadCopyRoom",
  "content": "You cannot disable the restriction on downloading and copying data because this setting is enforced at the room level for all files.",
  "content_en_sha1_hash": "5fc62c010d3055bab64d90486b438d05848dc72f",
  "created_at": "2025-08-26T11:15:00.099Z",
