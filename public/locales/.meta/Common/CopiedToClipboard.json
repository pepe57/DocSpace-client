    "text": "This key displays a success message to the user confirming that code has been copied to the clipboard. It appears as a toast notification after the copy action is performed within a code block in the chat interface. Translators should ensure the wording accurately conveys a successful copy operation.",
    "is_auto": true,
    "updated_at": "2025-11-25T11:54:16.679Z"
  },
