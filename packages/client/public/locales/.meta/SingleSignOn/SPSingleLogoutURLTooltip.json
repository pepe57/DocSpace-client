  "comment": {
    "text": "The \"SPSingleLogoutURLTooltip\" translation key provides a tooltip message explaining the purpose of the \"SPSingleLogoutURL\" field in the Portal Settings UI. It is used to inform users about the URL associated with single logout on the Identity provider side when setting up Single Sign-On (SSO) options, typically displayed in a button or dialog context.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:46:02.944Z"
  },
