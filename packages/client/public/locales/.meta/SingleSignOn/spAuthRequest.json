  "comment": {
    "text": "The \"spAuthRequest\" translation key is used to display the English content \"Sign Auth Requests\" in various UI elements, primarily found on checkboxes related to Single Sign-On (SSO) settings. This text likely appears as a label for checkbox components in a portal settings page or similar interface.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:46:07.085Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/integration/SingleSignOn/sub-components/CheckboxSet.js",
      "line_number": 104,
      "context": ": \"sp-sign-auth-requests\"\n }\n className=\"checkbox-input\"\n isDisabled={isDisabled}\n onChange={setCheckbox}\n label={prefix === \"idp\" ? t(\"idpAuthRequest\") : t(\"spAuthRequest\")}\n name={checkboxesNames[prefix][0]}\n tabIndex={10}\n isChecked={\n prefix === \"idp\" ? idpVerifyAuthResponsesSign : spSignAuthRequests\n }",
      "module": "/packages/client"
    }
