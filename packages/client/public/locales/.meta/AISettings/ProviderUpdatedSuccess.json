      "line_number": 396,
      "context": "data.modelSettings = buildUpdateDelta(allSettings);\n }\n \n await updateAIProvider?.(providerData.id, data);\n toastr.success(\n t(\"AISettings:ProviderUpdatedSuccess\", {\n aiProvider: t(\"Common:AIProvider\"),\n }),\n );\n }",
      "module": "/packages/client"
    }
