{
  "key_path": "ToUseAddProvider",
  "content": "To use {{value}}, make sure to connect at least one {{aiProvider}} first.",
  "content_en_sha1_hash": "7ac37664b2a8a6b4459dada1c0cb3184e8fd4a9b",
  "created_at": "2025-12-17T14:56:14.846Z",
  "updated_at": "2026-05-15T14:00:06.760Z",
  "comment": {
    "text": "This is a tooltip text that appears when a user tries to use an AI-powered feature (like AI Knowledge, Web Search AI, or an MCP server) without having any AI providers connected. It informs the user that they need to connect an AI provider first. `{{value}}` is the name of the feature, and `{{aiProvider}}` is the general term for an AI provider.",
    "is_auto": true,
    "updated_at": "2026-04-11T21:02:16.102Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/ai-settings/knowledge/index.tsx",
      "line_number": 262,
      "context": "<div\n className={generalStyles.search}\n data-tooltip-id={tooltipId}\n data-tooltip-content={\n !hasAIProviders\n ? t(\"AISettings:ToUseAddProvider\", {\n value: t(\"AIRoom:Knowledge\"),\n aiProvider: t(\"Common:AIProvider\"),\n })\n : undefined\n }",
      "module": "/packages/client"
    },
    {
