      "line_number": 123,
      "context": "case \"WebDav\":\n return t(\"Translations:FolderTitleWebDav\");\n case \"kDrive\":\n return t(\"Translations:FolderTitlekDrive\");\n case \"Yandex\":\n return t(\"Translations:FolderTitleYandex\");\n \n default:\n return key;\n }\n };",
