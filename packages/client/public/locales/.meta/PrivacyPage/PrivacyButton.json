  "comment": {
    "text": "This key provides the label text for a button on the Private Rooms Page. The button, when clicked, opens the OnlyOffice desktop editors. The text includes a dynamic placeholder for the brand name, which must be correctly translated and formatted.",
    "is_auto": true,
    "updated_at": "2026-04-11T18:35:59.541Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PrivateRoomsPage/index.js",
      "line_number": 196,
      "context": "<Button\n onClick={onOpenEditorsPopup}\n size=\"medium\"\n primary\n isDisabled={isDisabled}\n label={t(\"PrivacyButton\", {\n OnlyofficeDesktopEditors: getBrandName(\"OnlyofficeDesktopEditors\"),\n })}\n />\n \n <label className=\"privacy-rooms-text-separator\" />",
      "module": "/packages/client"
    }
  ],
