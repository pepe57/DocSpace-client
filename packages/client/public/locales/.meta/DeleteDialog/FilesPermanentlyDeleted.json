  "comment": {
    "text": "This is a sentence fragment in a confirmation dialog. It informs the user that files will be permanently deleted from the trash. `{{trashSection}}` is a variable representing the name of the trash section (e.g., \"Trash\").",
    "is_auto": true,
    "updated_at": "2026-04-11T21:05:24.945Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/components/dialogs/DeleteDialog/DeleteDialog.helper.js",
      "line_number": 188,
      "context": "<>\n <Trans t={t} i18nKey=\"DeleteFilesForever\" ns=\"DeleteDialog\">\n You are about to delete <strong>files ({{ filesCount }})</strong>.\n </Trans>{\" \"}\n {!isThirdParty\n ? t(\"FilesPermanentlyDeleted\", {\n trashSection: t(\"Common:TrashSection\"),\n })\n : t(\"DeleteItemsSharedNote\")}{\" \"}\n {t(\"Common:WantToContinue\")}\n </>",
      "module": "/packages/client"
    }
