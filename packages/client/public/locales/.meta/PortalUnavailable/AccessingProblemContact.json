  "comment": {
    "text": "This is an error message displayed in a dialog when a user cannot access the product. It informs the user to contact the administrator and includes a variable `{{productName}}` which will be replaced with the actual product name (e.g., ONLYOFFICE DocSpace).",
    "is_auto": true,
    "updated_at": "2026-04-11T21:20:22.742Z",
