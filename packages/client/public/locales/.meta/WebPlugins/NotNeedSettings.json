  "comment": {
    "text": "This translation key is used to display the text \"Not need enter settings\" in a settings plugin dialog. It appears as part of a button or similar UI element that indicates whether entering settings is necessary or not. The text helps users understand their current status and navigate accordingly.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:46:41.462Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/components/dialogs/SettingsPluginDialog/sub-components/Info.tsx",
      "line_number": 46,
      "context": "const locale = getCookie(LANGUAGE) || \"en\";\n const uploadDate = plugin.createOn && getCorrectDate(locale, plugin.createOn);\n \n const pluginStatus =\n plugin.status === PluginStatus.active\n ? t(\"NotNeedSettings\")\n : t(\"NeedSettings\");\n \n const incompatibleTooltip = t(\"WebPlugins:PluginIsNotCompatible\", {\n productName: t(\"Common:ProductName\"),\n });",
      "module": "/packages/client"
    }
