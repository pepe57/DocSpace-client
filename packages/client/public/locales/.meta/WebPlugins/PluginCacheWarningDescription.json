  "comment": {
    "text": "This translation key provides a warning message displayed in a dialog to inform users that plugin changes require an incremented version number in the package.json file to be applied. It explains why the plugin might not be updating and guides users on how to resolve this. This message helps users understand plugin update behavior.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:30:46.646Z"
  },
