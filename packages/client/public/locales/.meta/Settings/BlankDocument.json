  "comment": {
    "text": "This key provides the title for a blank Microsoft Word document template. It is used to label the template when creating a new document within the application. Translators should ensure the title is clear and descriptive of a new, empty Word document.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:29:09.808Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/store/portal-settings/DefaultTemplatesStore.ts",
      "line_number": 69,
      "context": "};\n \n getTitleByExt = (ext: string) => {\n switch (ext) {\n case \".docx\":\n return i18n.t(\"Settings:BlankDocument\");\n case \".xlsx\":\n return i18n.t(\"Settings:BlankSpreadsheet\");\n case \".pptx\":\n return i18n.t(\"Settings:BlankPresentation\");\n case \".pdf\":",
      "module": "/packages/client"
    }
