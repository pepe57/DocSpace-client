      "line_number": 73,
      "context": "case \".docx\":\n return i18n.t(\"Settings:BlankDocument\");\n case \".xlsx\":\n return i18n.t(\"Settings:BlankSpreadsheet\");\n case \".pptx\":\n return i18n.t(\"Settings:BlankPresentation\");\n case \".pdf\":\n return i18n.t(\"Settings:BlankForm\");\n }\n };",
