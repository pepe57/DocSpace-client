  "comment": {
    "text": "This key provides the title for a blank spreadsheet template. It appears as the name of the default spreadsheet file when creating a new document. Translators should ensure the title accurately reflects an empty, ready-to-use spreadsheet.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:28:30.969Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/store/portal-settings/DefaultTemplatesStore.ts",
      "line_number": 71,
      "context": "getTitleByExt = (ext: string) => {\n switch (ext) {\n case \".docx\":\n return i18n.t(\"Settings:BlankDocument\");\n case \".xlsx\":\n return i18n.t(\"Settings:BlankSpreadsheet\");\n case \".pptx\":\n return i18n.t(\"Settings:BlankPresentation\");\n case \".pdf\":\n return i18n.t(\"Settings:BlankForm\");\n }",
      "module": "/packages/client"
    }
