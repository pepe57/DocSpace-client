  "comment": {
    "text": "This is a description displayed on a step in the Google Workspace user import wizard. It explains how users are imported, specifically noting that Google Workspace users will have their email name used as their first/last name, and that existing users are highlighted. It contains `{{organizationName}}` (e.g., \"ONLYOFFICE\") and `{{productName}}` (e.g., \"DocSpace\") variables.",
    "is_auto": true,
    "updated_at": "2026-04-11T21:22:23.827Z",
