  "comment": {
    "text": "This is a line item in a list of quota limits, displayed within a warning dialog. It indicates the total storage limit for the entire tenant, with `{{tenantQuotaLimit}}` representing the specific storage amount (e.g., \"10 GB\") and `{{productName}}` being the name of the product (e.g., \"DocSpace\").",
    "is_auto": true,
    "updated_at": "2026-04-11T21:21:53.543Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/components/dialogs/WarningQuotaDialog/WarningQuotaDialog.tsx",
      "line_number": 78,
      "context": "}),\n );\n }\n if (isTenantCustomQuotaSet) {\n quotaLimits.push(\n t(\"Settings:TenantQuotaLimit\", {\n tenantQuotaLimit: getConvertedSize(t, tenantCustomQuota),\n productName: getBrandName(\"ProductName\"),\n }),\n );\n }",
      "module": "/packages/client"
    }
  ],
