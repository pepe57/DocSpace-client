  "comment": {
    "text": "The \"Leave blank to disable\" translation key is used in a password input field to provide a hint about what value would allow the feature to be disabled. It appears as a subtitle next to the label for the secret key input.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:45:15.657Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/integration/DocumentService/index.js",
      "line_number": 299,
      "context": "<Label\n htmlFor=\"secretKey\"\n text={t(\"Settings:DocumentServiceSecretKey\")}\n />\n <Text className=\"label-subtitle\">\n {`(${t(\"Settings:DocumentServiceSecretKeySubtitle\")})`}\n </Text>\n </div>\n <PasswordInput\n key={secretKeyVersion}\n id=\"secretKey\"",
      "module": "/packages/client"
    },
