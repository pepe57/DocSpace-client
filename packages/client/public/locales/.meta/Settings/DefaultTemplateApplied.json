  "comment": {
    "text": "This key displays a success message in the UI, confirming that a new default template has been applied. It appears as a toast notification after a template is successfully set, likely within the portal settings section. Translators should ensure the tone remains positive and informative.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:28:17.942Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/store/portal-settings/DefaultTemplatesStore.ts",
      "line_number": 105,
      "context": "setTemplate = async (selectedFile: number | null, fileExtension: string) => {\n try {\n const res = await setDefaultTemplates(selectedFile, fileExtension);\n this.formTemplatesArray(res);\n toastr.success(i18n.t(\"Settings:DefaultTemplateApplied\"));\n } catch (e) {\n toastr.error((e as TData) ?? i18n.t(\"Common:Error\"));\n }\n };",
      "module": "/packages/client"
    },
