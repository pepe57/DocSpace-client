    "text": "This key displays a success message in a toastr notification confirming that an AI agent quota has been disabled. The message includes the name of the AI agent, retrieved from a separate translation key \"Common:AIAgent\". Translators should ensure the AI agent name is accurately localized.",
    "is_auto": true,
    "updated_at": "2025-12-22T10:10:48.074Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/store/CurrentQuotaStore.ts",
      "line_number": 535,
      "context": "try {\n await setDefaultAIAgentQuota(isEnable, +quota);\n const toastrText = isEnable\n ? t(\"AIAgentQuotaEnabled\", { aiAgent: t(\"Common:AIAgent\") })\n : t(\"AIAgentQuotaDisabled\", { aiAgent: t(\"Common:AIAgent\") });\n \n toastr.success(toastrText);\n } catch (e: unknown) {\n toastr.error(e as TData);\n }",
      "module": "/packages/shared"
    }
  ],
