  "comment": {
    "text": "The RoomQuotaEnabled translation key is used to display a success message when room quota has been successfully enabled. This text appears in a toast notification after enabling room quota and is provided by the CurrentQuotaStore file.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:44:37.107Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/store/CurrentQuotaStore.ts",
      "line_number": 522,
      "context": "const isEnable = +quota !== -1;\n \n try {\n await setDefaultRoomQuota(isEnable, +quota);\n const toastrText = isEnable\n ? t(\"RoomQuotaEnabled\")\n : t(\"RoomQuotaDisabled\");\n \n toastr.success(toastrText);\n } catch (e: unknown) {\n toastr.error(e as TData);",
      "module": "/packages/shared"
    }
  ],
