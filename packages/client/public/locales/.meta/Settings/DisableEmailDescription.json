{
  "key_path": "DisableEmailDescription",
  "content": "If this box is checked, {{sectionName}} users will not need to verify their email after the first authorization in {{productName}}.",
  "content_en_sha1_hash": "2da0e4ca0cd6f8f333299141602af035c3a5f3b0",
  "created_at": "2025-05-19T21:30:51.190Z",
  "updated_at": "2026-05-15T14:00:06.844Z",
  "comment": {
    "text": "This is a tooltip for a checkbox. It explains that checking the box will disable email verification for users from a specific integration (LDAP or SSO) after their initial login. `{{sectionName}}` will be either \"LDAP\" or \"SSO\", and `{{productName}}` will be \"ONLYOFFICE DocSpace\".",
    "is_auto": true,
    "updated_at": "2026-04-11T21:24:33.898Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
