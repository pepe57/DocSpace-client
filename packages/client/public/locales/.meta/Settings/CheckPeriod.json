  "comment": {
    "text": "The \"Check period (sec)\" translation key is used to display the duration of time allowed for a check or validation process. In the Portal Settings category's security access-portal component, it appears as part of the brute force protection settings and indicates how often checks should be performed on user login attempts.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:45:33.283Z"
  },
  "usage": [
