{
  "key_path": "DefaultTemplateRestored",
  "content": "Default template has been restored.",
  "content_en_sha1_hash": "d887a216e14f93de098f3b3800ac56bc1a139b88",
  "created_at": "2026-02-18T14:56:26.397Z",
