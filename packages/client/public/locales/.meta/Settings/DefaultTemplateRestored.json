  "comment": {
    "text": "This key displays a success message in the UI, confirming that the default template has been successfully restored. It appears as a toastr notification after resetting a default template, indicating the action was completed successfully. Translators should ensure the message conveys a positive outcome for the user.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:28:01.739Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/store/portal-settings/DefaultTemplatesStore.ts",
      "line_number": 115,
      "context": "resetTemplate = async (fileExtension: string) => {\n try {\n const res = await resetDefaultTemplates(fileExtension);\n this.formTemplatesArray(res);\n toastr.success(i18n.t(\"Settings:DefaultTemplateRestored\"));\n } catch (e) {\n toastr.error((e as TData) ?? i18n.t(\"Common:Error\"));\n }\n };",
      "module": "/packages/client"
    }
  ],
