{
  "key_path": "DocumentServiceLocationUrlPortal",
  "content": "{{productName}} address for internal requests from the Document Service",
  "content_en_sha1_hash": "d3815a656c220dde785b033d7fcf88dd267536a4",
  "created_at": "2025-05-19T21:30:51.400Z",
  "updated_at": "2026-05-15T14:00:06.843Z",
  "comment": {
    "text": "This is a label for an input field in the Document Service integration settings. It prompts the user to enter the URL for internal requests, with `{{productName}}` replaced by the brand name (e.g., ONLYOFFICE DocSpace).",
    "is_auto": true,
    "updated_at": "2026-04-11T21:24:18.568Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/integration/DocumentService/index.js",
      "line_number": 400,
      "context": "</Text>\n </div>\n <div className=\"input-wrapper\">\n <Label\n htmlFor=\"portalAdress\"\n text={t(\"Settings:DocumentServiceLocationUrlPortal\", {\n productName: getBrandName(\"ProductName\"),\n })}\n />\n <InputBlock\n id=\"portalAdress\"",
      "module": "/packages/client"
    }
  ],
