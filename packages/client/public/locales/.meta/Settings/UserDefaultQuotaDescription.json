{
  "key_path": "UserDefaultQuotaDescription",
  "content": "Set the storage quota for users of this {{productName}}. User quota affects storage limit for the {{sectionName}} folder of each user.",
  "content_en_sha1_hash": "f458865eae0c8ae790107a81c760cf27584a9b51",
  "created_at": "2025-05-19T21:30:53.116Z",
  "updated_at": "2026-05-15T14:00:06.873Z",
  "comment": {
    "text": "This is a subtitle or toggle description explaining the user storage quota setting. It describes how the quota affects the \"My Documents\" folder for each user within the specified product. `{{productName}}` is the name of the product (e.g., ONLYOFFICE DocSpace), and `{{sectionName}}` is the name of the \"My Documents\" folder.",
    "is_auto": true,
    "updated_at": "2026-04-11T21:21:28.711Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/storage-management/sub-components/MobileQuotas.js",
      "line_number": 69,
      "context": "/>\n <CategoryItem\n title={t(\"QuotaPerUser\")}\n onClickLink={onClickLink}\n url=\"/portal-settings/management/disk-space/quota-per-user\"\n subtitle={t(\"UserDefaultQuotaDescription\", {\n productName: getBrandName(\"ProductName\"),\n sectionName: t(\"Common:MyDocuments\"),\n })}\n isDisabled={isDisabled}\n />",
      "module": "/packages/client"
    },
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/storage-management/sub-components/QuotaPerUser.js",
