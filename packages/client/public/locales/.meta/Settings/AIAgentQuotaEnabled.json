  "comment": {
    "text": "This key displays a success message in a toastr notification, confirming that the AI Agent quota has been enabled. The message includes the AI Agent name, which is retrieved from another translation key (\"Common:AIAgent\"). It appears after attempting to set the default AI Agent quota.",
    "is_auto": true,
    "updated_at": "2025-12-22T10:10:31.910Z"
  },
  "usage": [
    {
      "file_path": "/packages/shared/store/CurrentQuotaStore.ts",
      "line_number": 534,
      "context": "const isEnable = +quota !== -1;\n \n try {\n await setDefaultAIAgentQuota(isEnable, +quota);\n const toastrText = isEnable\n ? t(\"AIAgentQuotaEnabled\", { aiAgent: t(\"Common:AIAgent\") })\n : t(\"AIAgentQuotaDisabled\", { aiAgent: t(\"Common:AIAgent\") });\n \n toastr.success(toastrText);\n } catch (e: unknown) {\n toastr.error(e as TData);",
      "module": "/packages/shared"
    }
  ],
