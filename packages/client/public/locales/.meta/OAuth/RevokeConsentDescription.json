  "comment": {
    "text": "This is a description within a confirmation dialog, explaining the consequences of revoking consent for an authorized application. It appears when a user attempts to revoke access for an application. `{{organizationName}}` refers to the company name (e.g., ONLYOFFICE), `{{productName}}` is the product name (e.g., DocSpace), and `{{name}}` is the name of the third-party service.",
    "is_auto": true,
