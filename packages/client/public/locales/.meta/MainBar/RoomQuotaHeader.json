    "text": "This is a header for a quota bar, indicating that the number of rooms created is nearing or has reached the maximum allowed. `{{currentValue}}` is the current number of rooms, and `{{maxValue}}` is the maximum allowed.",
    "is_auto": true,
    "updated_at": "2026-04-11T21:17:39.064Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
