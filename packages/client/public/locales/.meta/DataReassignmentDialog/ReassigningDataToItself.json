  "comment": {
    "text": "This is a message displayed within a dialog box, informing the user that a data reassignment process has begun. It appears when a user initiates the reassignment of data from one user (represented by `{{fromUser}}`) to another (represented by `{{toUser}}`), where `{{you}}` indicates the current user if they are involved in the reassignment.",
    "is_auto": true,
