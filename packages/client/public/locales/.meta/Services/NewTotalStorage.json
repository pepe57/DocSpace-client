      "line_number": 399,
      "context": "<Text fontWeight={600}>\n {!hasStorageSubscription\n ? t(\"Services:AmoutWithStorageUnit\", {\n storageUnit: t(\"Common:Gigabyte\"),\n })\n : t(\"Services:NewTotalStorage\", {\n storageUnit: t(\"Common:Gigabyte\"),\n })}\n </Text>\n <FieldContainer\n isVertical",
      "module": "/packages/client"
    }
