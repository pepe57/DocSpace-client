  "comment": {
    "text": "This key displays the new total storage amount available to a user after a storage plan upgrade. It's used in the StoragePlanUpgrade panel within the Portal Settings, specifically shown when a user has an active storage subscription. The `storageUnit` variable (e.g., Gigabyte) will be dynamically inserted into the text.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:07:19.051Z"
  },
  "usage": [
