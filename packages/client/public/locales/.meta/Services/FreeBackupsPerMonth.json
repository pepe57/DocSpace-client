  "comment": {
    "text": "This translation key displays the number of free backups remaining for the current month. It's used to inform the user about their backup usage within the Portal Settings page, specifically within a warning component. The key includes variables for the current backup count (`value`) and the maximum allowed (`maxValue`).",
    "is_auto": true,
    "updated_at": "2025-08-21T14:48:15.206Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/Layout/WarningComponent/index.tsx",
      "line_number": 149,
      "context": ");\n let resultText: React.ReactNode = \"\";\n \n if (maxFreeBackups > 0) {\n try {\n const backupText = t(\"Services:FreeBackupsPerMonth\", {\n value:\n backupsCount >= maxFreeBackups ? maxFreeBackups : backupsCount,\n maxValue: maxFreeBackups,\n });",
      "module": "/packages/client"
    }
  ],
