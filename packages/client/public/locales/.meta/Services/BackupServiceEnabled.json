  "comment": {
    "text": "This key displays a success message in the UI, confirming that the backup service has been successfully enabled. It appears as a toastr notification within the Portal Settings page, specifically when enabling a service. Translators should ensure the message conveys a positive confirmation of the action.",
    "is_auto": true,
    "updated_at": "2025-08-21T14:48:52.013Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/payments/SaaS/services/index.tsx",
      "line_number": 352,
      "context": "changeServiceState(confirmActionType);\n \n const getSuccessMessage = () => {\n if (confirmActionType === BACKUP_SERVICE) {\n return t(\"Services:BackupServiceEnabled\");\n }\n if (confirmActionType === AI_ENUM) {\n return t(\"Services:AIToolsEnabled\");\n }\n };",
      "module": "/packages/client"
    }
  ],
