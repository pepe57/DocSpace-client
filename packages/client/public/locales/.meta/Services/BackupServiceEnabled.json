  "key_path": "BackupServiceEnabled",
  "content": "Backup service successfully enabled.",
  "content_en_sha1_hash": "8433fcfa744945fc664e221df15d13d454b4ab39",
  "created_at": "2025-08-21T14:45:38.905Z",
