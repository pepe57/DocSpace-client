  "comment": {
    "text": "This key displays the title for a wallet info section within a \"Top Up to AI\" transfer block in the Portal Settings. It shows the AI service balance and includes the organization's name dynamically inserted into the text (e.g., \"[Organization Name] AI\"). This appears in a dialog or modal related to topping up funds for AI services.",
    "is_auto": true,
    "updated_at": "2026-03-20T10:05:55.816Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/payments/SaaS/shared/top-up-balance/sub-components/FromWalletToAi.tsx",
      "line_number": 97,
      "context": "<div className={modalStyles.transferBlock}>\n <Text fontWeight=\"600\">{t(\"Payments:TopUpTo\")}</Text>\n \n <WalletInfo\n title={t(\"Services:OrganizationAI\", {\n organizationName: logoText,\n })}\n balance={aiServiceBalanceValue}\n iconUrl={AiAgents}\n />",
      "module": "/packages/client"
    }
  ],
