  "comment": {
    "text": "The \"WebhookRemoved\" translation key is used to display a success message when a webhook is removed in the Portal Settings. This message is typically shown after a button or action that deletes a webhook, and it indicates that the removal process has been completed successfully.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:46:44.814Z"
  },
