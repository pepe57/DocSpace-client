      "context": "};\n \n const handleWebhookDelete = async () => {\n try {\n await deleteWebhook(currentWebhook);\n toastr.success(t(\"WebhookRemoved\"));\n } catch (error) {\n toastr.error(error);\n }\n };",
      "module": "/packages/client"
    }
