  "comment": {
    "text": "The \"UserInvited\" translation key is used to display a message indicating that a user has been invited. It appears in webhooks related to user invitations and serves as a descriptive label. Translators should provide a clear and concise text for this key.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:46:48.502Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/developer-tools/Webhooks/Webhooks.helpers.ts",
      "line_number": 34,
      "context": "export const getTriggerTranslate = (trigger: number, t: TTranslation) => {\n switch (trigger) {\n case WebhookTriggers.UserCreated:\n return t(\"UserCreated\");\n case WebhookTriggers.UserInvited:\n return t(\"UserInvited\");\n case WebhookTriggers.UserUpdated:\n return t(\"UserUpdated\");\n case WebhookTriggers.UserDeleted:\n return t(\"UserDeleted\");",
      "module": "/packages/client"
    }
  ],
