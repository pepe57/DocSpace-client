  "comment": {
    "text": "This translation key is used to display the phrase \"Auth via NTLM\" as a label for a checkbox in a settings UI. When checked, it likely enables authentication using NTLM protocol. It appears in the SMTP Settings page under Custom Settings.",
    "is_auto": true,
    "updated_at": "2025-05-20T09:44:02.152Z"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/PortalSettings/categories/integration/SMTPSettings/sub-components/CustomSettings.js",
      "line_number": 167,
      "context": "/>\n \n <Checkbox\n className=\"smtp_settings_checkbox\"\n name={USE_NTLM}\n label={t(\"AuthViaNTLM\")}\n isChecked={settings[USE_NTLM]}\n onChange={onChangeCheckbox}\n isDisabled={isLoading || !settings[AUTHENTICATION]}\n dataTestId=\"smtp_auth_ntlm_checkbox\"\n />",
      "module": "/packages/client"
    }
  ],
