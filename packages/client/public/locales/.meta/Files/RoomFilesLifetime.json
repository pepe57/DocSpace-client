  "comment": {
    "text": "This is a tooltip that appears when hovering over an icon in a room, indicating the file lifetime setting for that room. It includes variables for the number of `days` and the `period` (e.g., \"days\", \"weeks\", \"months\").",
    "is_auto": true,
    "updated_at": "2026-04-11T21:08:26.272Z",
    "model": "google/gemini-2.5-flash"
  },
  "usage": [
    {
      "file_path": "/packages/client/src/pages/Home/Section/Header/index.js",
      "line_number": 575,
      "context": "const titleIconTooltip = React.useMemo(() => {\n if (sharedType) return t(\"Files:RecentlyOpenedTooltip\");\n \n if (lifetime)\n return `${t(\"Files:RoomFilesLifetime\", {\n days: lifetime.value,\n period: getLifetimePeriodTranslation(lifetime.period, t),\n })}. ${\n lifetime.deletePermanently\n ? t(\"Files:AfterFilesWillBeDeletedPermanently\")",
      "module": "/packages/client"
    }
  ],
