  "comment": {
    "text": "This is a sentence fragment that appears in a tooltip. It describes a shared link's protection settings, indicating that the link is protected by a specific method (e.g., password, expiration date). The `{{parameter}}` variable will be replaced by the name of the protection method.",
    "is_auto": true,
    "updated_at": "2026-04-11T21:15:22.718Z",
