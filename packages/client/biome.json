{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "extends": [
    "../shared/biome.json"
  ],
  "plugins": [
    "../shared/biome-plugins/no-dynamic-i18n-key.grit",
    "../shared/biome-plugins/no-constants-via-i18n.grit"
  ],
  "files": {
    "includes": [
      "**",
      "!tsconfig.json",
      "!node_modules/*",
      "!dist/*",
      "!coverage/*",
      "!storybook-static/*",
      "!**/autoGeneratedTranslations.js",
      "!**/autoGeneratedTranslations.ts",
      "!tests/*",
      "!scripts/*",
      "!**/*.html",
      "!__tests__/plugins/*"
    ]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noFallthroughSwitchClause": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "__tests__/fixtures/**"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noEmptyPattern": "off"
          }
        }
      }
    }
  ]
}