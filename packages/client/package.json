{
  "name": "@docspace/client",
  "version": "3.6.1",
  "private": true,
  "homepage": "",
  "scripts": {
    "build": "vite build",
    "build:translations": "node scripts/buildTranslations.js",
    "clean": "shx rm -rf dist",
    "deploy": "shx --silent mkdir -p ../../../publish/web/client && shx cp -r dist/* ../../../publish/web/client",
    "start": "vite",
    "start-prod": "serve dist -s -p 5001",
    "analyze": "vite build --mode analyze",
    "test:build": "cross-env PORT=5110 E2E_TEST=true pnpm run build:translations && pnpm run build",
    "test:start": "cross-env PORT=5110 NODE_ENV=production E2E_TEST=true serve dist -s -p 5110",
    "test:e2e:docker:build": "docker-compose build",
    "test:e2e:docker:start": "docker-compose run --rm tests-local pnpm exec playwright test",
    "test:e2e:docker:update-screenshots": "docker-compose run --rm tests-local pnpm exec playwright test --update-snapshots",
    "test:e2e:docker:clear": "docker rmi client-tests",
    "test:e2e:docker:dev": "docker-compose run --rm tests-dev pnpm exec playwright test",
    "test:e2e:docker:dev:update-screenshots": "docker-compose run --rm tests-dev pnpm exec playwright test --update-snapshots",
    "test:e2e:ui": "pnpm run test:build && cross-env PORT=5110 pnpm exec playwright test --ui",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome check ./src",
    "format:fix": "biome check --write ./src",
    "tsc": "tsc"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "6.2.2",
    "@docspace/shared": "workspace:*",
    "@docspace/ui-kit": "workspace:*",
    "@onlyoffice/docspace-sdk-js": "file:onlyoffice-docspace-sdk-js-2.2.0.tgz",
    "@react-spring/web": "9.7.5",
    "@tanstack/react-query": "^5.90.20",
    "@uiw/codemirror-theme-github": "4.23.5",
    "@uiw/react-codemirror": "4.23.5",
    "@use-gesture/react": "10.3.1",
    "axios": "1.13.5",
    "classnames": "2.5.1",
    "copy-to-clipboard": "3.3.3",
    "cross-fetch": "3.1.8",
    "crypto-js": "4.2.0",
    "csvjson-json_beautifier": "5.0.4",
    "element-resize-detector": "1.2.4",
    "email-addresses": "3.1.0",
    "fast-deep-equal": "3.1.3",
    "file-saver": "2.0.5",
    "firebase": "11.2.0",
    "heic2any": "0.0.4",
    "hex-rgb": "5.0.0",
    "i18next": "23.7.19",
    "lodash": "4.17.23",
    "lodash.debounce": "4.0.8",
    "luxon": "3.7.2",
    "mobx": "6.13.5",
    "mobx-react": "7.6.0",
    "msw": "^2.12.7",
    "prop-types": "15.8.1",
    "query-string": "7.1.3",
    "queue-promise": "2.2.1",
    "react": "19.2.4",
    "react-avatar-editor": "^14.0.0",
    "react-device-detect": "2.2.3",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-hotkeys-hook": "3.4.7",
    "react-i18next": "14.0.1",
    "react-markdown": "^10.1.0",
    "react-router": "7.12.0",
    "react-smartbanner": "5.1.4",
    "react-string-format": "0.1.4",
    "react-svg": "16.1.34",
    "react-toastify": "10.0.6",
    "react-tooltip": "5.28.0",
    "react-virtualized": "^9.22.6",
    "react-virtualized-auto-sizer": "1.0.24",
    "react-window": "1.8.10",
    "react-window-infinite-loader": "1.0.9",
    "remark-gfm": "4.0.1",
    "resize-image": "0.1.0",
    "sjcl": "1.0.8",
    "socket.io-client": "4.8.3",
    "styled-components": "5.3.11",
    "ts-pattern": "5.5.0",
    "utif": "3.1.0",
    "windows-iana": "5.1.0",
    "workbox-window": "6.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@onlyoffice/docspace-plugin-sdk": "file:onlyoffice-docspace-plugin-sdk-2.1.0.tgz",
    "@playwright/test": "1.58.1",
    "@types/crypto-js": "4.2.2",
    "@types/element-resize-detector": "1.1.6",
    "@types/he": "1.2.3",
    "@types/lodash": "4.17.10",
    "@types/lodash.debounce": "^4.0.9",
    "@types/luxon": "3.7.1",
    "@types/react": "19.2.10",
    "@types/react-virtualized": "9.21.30",
    "@types/react-window": "1.8.8",
    "@types/react-window-infinite-loader": "1.0.9",
    "@types/styled-components": "5.1.34",
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^10.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "1.79.6",
    "serve": "14.2.5",
    "shx": "0.4.0",
    "typescript": "5.9.3",
    "use-resize-observer": "9.1.0",
    "vite": "^6.4.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "title": "ONLYOFFICE",
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "start": {
        "continuous": true,
        "dependsOn": [
          "build:translations"
        ]
      },
      "start-prod": {
        "continuous": true,
        "dependsOn": [
          "build"
        ]
      },
      "lint": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "lint:fix": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "tsc": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "deploy": {
        "dependsOn": [
          "build"
        ]
      }
    }
  }
}
