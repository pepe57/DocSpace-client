{
  "extends": "../shared/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "baseUrl": "./",
    "jsx": "react-jsx",
    "paths": {
      "PUBLIC_DIR/*": ["../../public/*"],
      "ASSETS_DIR/*": ["./public/*"],
      "SRC_DIR/*": ["./src/*"],
      "PACKAGE_FILE": ["./package.json"],
      "COMMON_DIR/*": ["../common/*"],
      "@docspace/shared/*": ["../shared/*"],
      "@docspace/ui-kit/*": ["../../libs/ui-kit/*"]
    },
    "target": "esnext",
    "types": ["vite/client"]
  },
  "include": ["**/*.ts", "**/*.tsx", "types/**/*.d.ts", "vite.config.ts"]
}
