{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "extends": [
    "../shared/biome.json"
  ],
  "plugins": [
    "../shared/biome-plugins/no-dynamic-i18n-key.grit",
    "../shared/biome-plugins/no-constants-via-i18n.grit"
  ],
  "linter": {
    "rules": {
      "performance": {
        "noImgElement": "error",
        "useGoogleFontPreconnect": "error",
        "noUnwantedPolyfillio": "error"
      },
      "style": {
        "noHeadElement": "error"
      },
      "suspicious": {
        "noDocumentImportInPage": "error",
        "noHeadImportInDocument": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!tsconfig.json",
      "!node_modules/*",
      "!.next/*",
      "!coverage/*",
      "!storybook-static/*",
      "!*/**/autoGeneratedTranslations.js",
      "!*/**/autoGeneratedTranslations.ts",
      "!webpack.config.js",
      "!tests/*"
    ]
  }
}