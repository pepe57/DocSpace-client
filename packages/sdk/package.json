{
  "name": "@docspace/sdk",
  "version": "3.7.0",
  "private": true,
  "scripts": {
    "build:translations": "node ./scripts/buildTranslations.js",
    "build": "next build --webpack",
    "build:deploy": "cross-env DEPLOY=true next build --webpack",
    "start": "cross-env NODE_ENV=development PORT=5099 NODE_OPTIONS=--use-system-ca next dev --webpack",
    "start-prod": "cross-env NODE_ENV=production NODE_OPTIONS=--use-system-ca node server.js",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "prettier --check ./src",
    "format:fix": "prettier --write ./src",
    "tsc": "tsc",
    "clean": "shx rm -rf .next",
    "deploy": "shx --silent mkdir -p ../../../publish/web/sdk && shx cp -r .next/standalone/* ../../../publish/web/sdk && shx --silent mkdir -p ../../../publish/web/sdk/packages/sdk/.next/static && shx cp -r .next/static/* ../../../publish/web/sdk/packages/sdk/.next/static && shx cp -f server.prod.js ../../../publish/web/sdk/server.js",
    "test:build": "cross-env E2E_TEST=true next build --webpack",
    "test:start": "cross-env NODE_ENV=production E2E_TEST=true node server.js",
    "test:e2e:docker:build": "docker-compose build",
    "test:e2e:docker:start": "docker-compose run --rm tests-local npx playwright test",
    "test:e2e:docker:update-screenshots": "docker-compose run --rm tests-local npx playwright test --update-snapshots",
    "test:e2e:docker:dev": "docker-compose run --rm tests-dev pnpm exec playwright test",
    "test:e2e:docker:dev:update-screenshots": "docker-compose run --rm tests-dev pnpm exec playwright test --update-snapshots",
    "test:e2e:docker:clear": "docker rmi tests",
    "test:e2e:ui": "pnpm run test:build && pnpm exec playwright test --ui",
    "test:clean-failed-tests": "node scripts/cleanFailedTests.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@docspace/shared": "workspace:*",
    "@docspace/ui-kit": "workspace:*",
    "classnames": "2.5.1",
    "date-and-time": "3.6.0",
    "i18next": "23.7.19",
    "lodash": "4.18.1",
    "mobx": "6.13.5",
    "mobx-react": "7.6.0",
    "nconf": "0.12.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "14.0.1",
    "react-joyride": "^3.0.0",
    "react-router": "7.12.0",
    "react-svg": "16.1.34",
    "react-virtualized": "^9.22.6",
    "sass": "1.79.6",
    "ts-pattern": "5.5.0",
    "winston": "3.17.0",
    "winston-cloudwatch": "6.3.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "3.981.0",
    "@babel/core": "7.25.8",
    "@biomejs/biome": "2.3.14",
    "@next/bundle-analyzer": "16.1.6",
    "@playwright/test": "1.58.1",
    "@svgr/webpack": "8.1.0",
    "@types/lodash": "4.17.10",
    "@types/node": "24.10.7",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@types/react-virtualized": "9.21.30",
    "cross-env": "^10.1.0",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "shx": "0.4.0",
    "terser-webpack-plugin": "5.3.16",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "build:deploy": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "start": {
        "continuous": true,
        "dependsOn": [
          "build:translations"
        ]
      },
      "start-prod": {
        "continuous": true,
        "dependsOn": [
          "build"
        ]
      },
      "lint": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "lint:fix": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "tsc": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "deploy": {
        "dependsOn": [
          "build:deploy"
        ]
      },
      "test:build": {
        "dependsOn": [
          "build:translations"
        ]
      }
    }
  }
}