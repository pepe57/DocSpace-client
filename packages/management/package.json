{
  "name": "@docspace/management",
  "version": "3.6.1",
  "private": true,
  "scripts": {
    "build:translations": "node scripts/buildTranslations.js",
    "build": "next build --webpack",
    "build:deploy": "cross-env DEPLOY=true next build --webpack",
    "start": "cross-env NODE_ENV=development PORT=5015 next dev --webpack",
    "start-prod": "cross-env NODE_ENV=production node server.js",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "test:build": "cross-env E2E_TEST=true next build --webpack",
    "test:start": "cross-env NODE_ENV=production E2E_TEST=true API_HOST=http://127.0.0.1:5115 node server.js --app.port=5115",
    "test:e2e:docker:build": "docker-compose build",
    "test:e2e:docker:start": "docker-compose run --rm tests-local pnpm exec playwright test",
    "test:e2e:docker:update-screenshots": "docker-compose run --rm tests-local pnpm exec playwright test --update-snapshots",
    "test:e2e:docker:dev": "docker-compose run --rm tests-dev pnpm exec playwright test",
    "test:e2e:docker:dev:update-screenshots": "docker-compose run --rm tests-dev pnpm exec playwright test --update-snapshots",
    "test:e2e:docker:clear": "docker rmi management-tests",
    "test:e2e:ui": "pnpm run test:build && pnpm exec playwright test --ui",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "prettier --check ./src",
    "format:fix": "prettier --write ./src",
    "tsc": "tsc",
    "clean": "shx rm -rf .next",
    "deploy": "shx --silent mkdir -p ../../../publish/web/management && shx cp -r .next/standalone/* ../../../publish/web/management && shx --silent mkdir -p ../../../publish/web/management/packages/management/.next/static && shx cp -r .next/static/* ../../../publish/web/management/packages/management/.next/static && shx cp -f server.prod.js ../../../publish/web/management/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "3.981.0",
    "@babel/runtime": "7.28.3",
    "@docspace/shared": "workspace:*",
    "@docspace/ui-kit": "workspace:*",
    "axios": "1.13.5",
    "classnames": "2.5.1",
    "date-and-time": "3.6.0",
    "i18next": "23.7.19",
    "lodash": "4.17.23",
    "mobx": "6.13.5",
    "mobx-react": "7.6.0",
    "nconf": "0.12.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-device-detect": "2.2.3",
    "react-dom": "19.2.4",
    "react-i18next": "14.0.1",
    "react-svg": "16.1.34",
    "resize-image": "0.1.0",
    "sass": "1.97.3",
    "ts-pattern": "5.5.0",
    "windows-iana": "5.1.0",
    "winston": "3.17.0",
    "winston-cloudwatch": "6.3.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.25.8",
    "@babel/plugin-proposal-export-default-from": "7.25.8",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/plugin-transform-runtime": "7.25.7",
    "@babel/preset-env": "7.25.8",
    "@babel/preset-react": "7.25.7",
    "@babel/preset-typescript": "7.25.7",
    "@biomejs/biome": "2.3.14",
    "prettier": "^3.8.1",
    "@next/bundle-analyzer": "16.1.6",
    "@playwright/test": "1.58.1",
    "@svgr/webpack": "8.1.0",
    "@types/lodash": "4.17.10",
    "@types/nconf": "0.10.7",
    "@types/node": "24.10.7",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "cross-env": "^10.1.0",
    "css-loader": "6.11.0",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "sass": "1.79.6",
    "sass-loader": "16.0.5",
    "shx": "0.4.0",
    "style-loader": "3.3.4",
    "terser-webpack-plugin": "5.3.16",
    "typescript": "5.9.3"
  },
  "title": "ONLYOFFICE",
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "build:deploy": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "start": {
        "continuous": true,
        "dependsOn": [
          "build:translations"
        ]
      },
      "start-prod": {
        "continuous": true,
        "dependsOn": [
          "build"
        ]
      },
      "lint": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "lint:fix": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "tsc": {
        "dependsOn": [
          "build:translations"
        ]
      },
      "deploy": {
        "dependsOn": [
          "build:deploy"
        ]
      }
    }
  }
}