APP_ROOT_PATH=
PORT=3001
OLLAMA_API_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma4:latest
BASE_LANGUAGE=en
FIGMA_API_KEY=

# OpenRouter (set OPENROUTER_API_KEY to auto-switch from Ollama)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it

# Per-task model overrides (optional, falls back to OPENROUTER_MODEL)
# Spell-check / translation verification — needs strong multilingual model
OPENROUTER_SPELLCHECK_MODEL=anthropic/claude-sonnet-4
# Auto-comment generation — simpler task, fast/cheap model is fine
OPENROUTER_COMMENT_MODEL=google/gemini-2.5-flash-lite
