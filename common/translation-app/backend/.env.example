APP_ROOT_PATH=
PORT=3001
OLLAMA_API_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma4:26b
BASE_LANGUAGE=en
FIGMA_API_KEY=

# OpenRouter (set OPENROUTER_API_KEY to auto-switch from Ollama)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Per-task model overrides (optional, falls back to OPENROUTER_MODEL)
# Spell-check / translation verification — needs strong multilingual model
OPENROUTER_SPELLCHECK_MODEL=anthropic/claude-sonnet-4
# Auto-comment generation — simpler task, fast/cheap model is fine
OPENROUTER_COMMENT_MODEL=google/gemini-2.5-flash

# Parallel LLM calls (speeds up spell-check proportionally)
SPELLCHECK_CONCURRENCY=5

# Reasoning/thinking effort for spell-check: off | low | medium | high
# - ollama:      maps to the native `think` param (boolean | low | medium | high)
# - openrouter:  sends `reasoning: { effort }` (OpenAI/Grok-style models)
# - claude-code: prepends "think"/"think hard"/"ultrathink" to the prompt
# The --thinking CLI flag overrides this. Leave empty to keep provider defaults.
SPELLCHECK_THINKING=

# LM Studio (local OpenAI-compatible server, default port 1234)
# Start LM Studio → Developer → Start Server, then load a model
LMSTUDIO_API_URL=http://localhost:1234/v1
# Optional API key if the LM Studio server is configured to require one
LMSTUDIO_API_KEY=
# Default model — use the exact model ID shown in LM Studio's loaded models list
LMSTUDIO_MODEL=
# Per-task model overrides (optional, falls back to LMSTUDIO_MODEL)
LMSTUDIO_SPELLCHECK_MODEL=
LMSTUDIO_COMMENT_MODEL=

# Claude Code CLI provider (--provider=claude-code, uses subscription)
# Accepts aliases: sonnet, opus, haiku — or full IDs: claude-sonnet-4-6
CLAUDE_CODE_MODEL=sonnet
